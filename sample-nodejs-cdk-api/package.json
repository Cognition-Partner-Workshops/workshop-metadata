{
  "name": "sample-nodejs-cdk-api",
  "version": "1.0.0",
  "description": "Sample Node.js REST API with AWS CDK, deployed via GitLab CI/CD with no cold start (Provisioned Concurrency)",
  "main": "dist/bin/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest --passWithNoTests",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval never",
    "dev": "ts-node src/local.ts"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "aws-cdk": "^2.170.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@vendia/serverless-express": "^4.12.6",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.3.0",
    "express": "^4.18.3"
  }
}
