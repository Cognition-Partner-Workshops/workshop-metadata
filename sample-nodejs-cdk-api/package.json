{
  "name": "sample-nodejs-cdk-api",
  "version": "1.0.0",
  "description": "Sample Node.js REST API with AWS CDK — EC2 + API Gateway, deployed via GitLab CI/CD with zero latency",
  "main": "bin/app.js",
  "scripts": {
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval never",
    "dev": "node src/local.js"
  },
  "devDependencies": {
    "aws-cdk": "^2.170.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.3.0",
    "express": "^4.18.3"
  }
}
