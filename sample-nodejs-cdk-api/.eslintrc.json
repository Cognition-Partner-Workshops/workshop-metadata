{
  "root": true,
  "extends": ["eslint:recommended"],
  "env": {
    "node": true,
    "jest": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "ignorePatterns": ["cdk.out/", "node_modules/"]
}
